{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "completed_work",
    "files_changed",
    "commands_run",
    "blockers",
    "ready_for_test",
    "skills_used",
    "skill_evidence",
    "subagent_usage"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "completed_work": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ready_for_test": {
      "type": "boolean"
    },
    "skills_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skill_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "evidence"],
        "properties": {
          "skill": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "subagent_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget", "spawned", "notes"],
      "properties": {
        "budget": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "spawned": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
