{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "implementation_steps",
    "validation_commands",
    "acceptance_criteria",
    "risks",
    "skills_used",
    "skill_evidence",
    "subagent_usage"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "implementation_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skill_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "evidence"],
        "properties": {
          "skill": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "subagent_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget", "spawned", "notes"],
      "properties": {
        "budget": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "spawned": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
