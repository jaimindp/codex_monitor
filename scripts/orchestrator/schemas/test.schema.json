{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "passed",
    "ready_for_pr",
    "checks",
    "residual_risks",
    "coverage_notes",
    "skills_used",
    "skill_evidence",
    "subagent_usage"
  ],
  "properties": {
    "passed": {
      "type": "boolean"
    },
    "ready_for_pr": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command", "status", "details"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "not_run"]
          },
          "details": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverage_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skill_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "evidence"],
        "properties": {
          "skill": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "subagent_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget", "spawned", "notes"],
      "properties": {
        "budget": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "spawned": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
