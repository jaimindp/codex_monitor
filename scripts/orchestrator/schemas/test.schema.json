{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "passed",
    "ready_for_pr",
    "checks",
    "residual_risks",
    "coverage_notes"
  ],
  "properties": {
    "passed": {
      "type": "boolean"
    },
    "ready_for_pr": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command", "status", "details"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "not_run"]
          },
          "details": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coverage_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
